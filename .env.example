# Database
DATABASE_URL="postgresql://user:password@localhost:5432/inventoryalert"

# NextAuth
NEXTAUTH_SECRET="replace-with-32-char-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Public base URL (used for QR code URL construction)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Resend
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="alerts@yourdomain.com"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_FAMILY="price_..."
STRIPE_PRICE_ENTERPRISE="price_..."
# Optional: use Stripe Product IDs so checkout/pricing always follow each product's default price
STRIPE_PRODUCT_FAMILY="prod_..."
STRIPE_PRODUCT_ENTERPRISE="prod_..."

# Vercel Blob
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# Web Push (VAPID) — required for phone push notifications
# Generate a keypair once with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"
